{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "editorial",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path');h.createServer((q,r)=>{let fp=p.join(process.cwd(),q.url==='/'?'editorial-engine.html':q.url);f.readFile(fp,(e,d)=>{if(e){r.writeHead(404);r.end()}else{r.writeHead(200,{'Content-Type':'text/html'});r.end(d)}})}).listen(8765)"],
      "port": 8765
    }
  ]
}
